# Copy to `.env` (gitignored) for local development: `cp config/development.env.example .env`
# In deployed environments these come from SSM under /mailman/<stage>/* instead.

NODE_ENV=development
STAGE=development
AWS_REGION=us-east-1
USE_AWS_PARAMETER_STORE=false

# --- Core (always required) ---
SERVICE_API_KEY=local-dev-key
SES_FROM_ADDRESS=Mailman Dev <notify@mail.example.com>
UNSUBSCRIBE_HMAC_SECRET=local-dev-unsubscribe-secret
APP_BASE_URL=https://app.example.com

# --- Optional: SES configuration set (only if feedback uses one) ---
# SES_CONFIGURATION_SET=mailman-events

# --- Optional: Supabase adapter (only if userId resolution / app suppression table) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
